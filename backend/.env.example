# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ID чата админа (узнать у @userinfobot)
ADMIN_CHAT_ID=YOUR_CHAT_ID_HERE

# Порт API-сервера
PORT=3100

# Домен сайта (для CORS)
SITE_URL=https://yourdomain.ru

# WhatsApp номер (без +)
WHATSAPP_PHONE=79001234567

# Telegram канал
TELEGRAM_CHANNEL=barberhouse_vrn

# Пароль для веб-админки (обязательно сменить!)
ADMIN_PASSWORD=your_secure_password_here

# Секрет для JWT-токенов (сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=
