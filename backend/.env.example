# ═══════════════════════════════════════════════
#  BARBER HOUSE — Backend Environment
# ═══════════════════════════════════════════════

# Пароль для входа в админку (/admin/)
ADMIN_PASSWORD=admin123

# Секрет для JWT (сгенерируйте: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Порт API (по умолчанию 3100)
PORT=3100

# Telegram-бот (опционально)
BOT_TOKEN=
ADMIN_CHAT_ID=

# URL сайта (для CORS, по умолчанию *)
SITE_URL=https://barber-house.academy

# Директория для загруженных изображений
# В production по умолчанию /var/www/barber/uploads
# Раскомментируйте для кастомного пути:
# UPLOAD_DIR=/var/www/barber/uploads
